<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="CoarseFineLocation">

    <!-- ══════════════════════════════════════════
         BLUETOOTH PERMISSIONS
         ══════════════════════════════════════════ -->
    <!-- Legacy (API < 31) -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <!-- Modern (API 31+) -->
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />

    <!-- ══════════════════════════════════════════
         SYSTEM / RUNTIME PERMISSIONS
         ══════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Required for foreground service type CONNECTED_DEVICE on API 34+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <!-- Keep CPU awake during BLE spam loop -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Show notifications on Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Optional: restart on boot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Network for update/bug report -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Location needed for BLE scan on older APIs -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"
        tools:ignore="CoarseFineLocation" />

    <!-- BLE is required -->
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.BLESpam"
        tools:targetApi="31">

        <!-- ══════════════════════════════════════
             ACTIVITIES
             ══════════════════════════════════════ -->
        <activity
            android:name=".SplashActivity"
            android:launchMode="singleTask"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.BLESpam" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.BLESpam" />

        <activity
            android:name=".BugReportActivity"
            android:exported="false"
            android:theme="@style/Theme.BLESpam" />

        <!-- ══════════════════════════════════════
             FOREGROUND SERVICE
             foregroundServiceType = connectedDevice required on API 34+
             ══════════════════════════════════════ -->
        <service
            android:name=".SpamService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- ══════════════════════════════════════
             BROADCAST RECEIVERS
             ══════════════════════════════════════ -->
        <receiver
            android:name=".StopSpamReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.tutozz.blespam.ACTION_STOP" />
            </intent-filter>
        </receiver>

        <!-- ══════════════════════════════════════
             APP WIDGET
             ══════════════════════════════════════ -->
        <receiver
            android:name=".SpammerWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.tutozz.blespam.widget.TOGGLE_APPLE" />
                <action android:name="com.tutozz.blespam.widget.TOGGLE_ANDROID" />
                <action android:name="com.tutozz.blespam.widget.TOGGLE_WINDOWS" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!-- ══════════════════════════════════════
             QUICK SETTINGS TILES
             ══════════════════════════════════════ -->
        <service
            android:name=".AppleTileService"
            android:exported="true"
            android:icon="@mipmap/ic_menu"
            android:label="Apple"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".AndroidTileService"
            android:exported="true"
            android:icon="@mipmap/ic_menu"
            android:label="Android"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".WindowsTileService"
            android:exported="true"
            android:icon="@mipmap/ic_menu"
            android:label="Windows"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".SamsungTileService"
            android:exported="true"
            android:icon="@mipmap/ic_menu"
            android:label="Samsung"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".YandexTileService"
            android:exported="true"
            android:icon="@mipmap/ic_menu"
            android:label="Yandex"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".XiaomiTileService"
            android:exported="true"
            android:icon="@mipmap/ic_menu"
            android:label="Xiaomi"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

    </application>

</manifest>
